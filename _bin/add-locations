#!/usr/bin/env perl
use v5.36;
use open ':std', ':encoding(UTF-8)';

use Encode qw(decode_utf8);
use FindBin;
use HTTP::Tiny;
use JSON::PP ();

# add-locations - look up place names and add them, as stub files, to the
# locations collection under _locations/.
#
# Usage:
#   _bin/add-locations PLACE [PLACE ...]
#
# For each PLACE, this geocodes the name with OpenStreetMap's Nominatim,
# shows what it found, and asks whether to add it. On confirmation a stub
# file (front matter with title/lat/lng and a TODO body) is written as
# _locations/<key>.md. You pick the key at the prompt -- the default is a
# slug of the place name, but "Rio de Janeiro" might deserve a tidier
# "rio". The key becomes the filename, the page slug, and the URL segment
# (/travel/<key>/), so it must match any `location:` used in posts.
# -- claude, 2026-07-04

my $LOCATIONS_DIR = "$FindBin::Bin/../_locations";

my $NOMINATIM = 'https://nominatim.openstreetmap.org/search';

my $http = HTTP::Tiny->new(
  # Nominatim's usage policy requires an identifying User-Agent with a way
  # to make contact. -- claude, 2026-07-03
  agent   => 'rjbs.cloud add-locations (hello@rjbs.cloud)',
  timeout => 20,
);

my $json = JSON::PP->new->utf8;

sub uri_escape ($str) {
  utf8::encode($str);
  $str =~ s/([^A-Za-z0-9_.~-])/sprintf '%%%02X', ord $1/ge;
  return $str;
}

sub slugify ($str) {
  my $slug = lc $str;
  $slug =~ s/[^a-z0-9]+/-/g;
  $slug =~ s/\A-+|-+\z//g;
  return $slug;
}

# Query Nominatim for one place name, returning the best match as a hash
# (or undef if nothing was found or the request failed). -- claude, 2026-07-03
sub geocode ($query) {
  my $url = "$NOMINATIM?q=" . uri_escape($query) . '&format=jsonv2&limit=1';

  my $res = $http->get($url);
  unless ($res->{success}) {
    warn "  lookup failed: $res->{status} $res->{reason}\n";
    return undef;
  }

  my $results = eval { $json->decode($res->{content}) };
  return undef unless $results && @$results;
  return $results->[0];
}

# YAML-quote a scalar for a double-quoted front-matter value. -- claude, 2026-07-04
sub yaml_dq ($str) {
  $str =~ s/(["\\])/\\$1/g;
  return qq{"$str"};
}

sub stub_for ($title, $lat, $lng) {
  my $q_title = yaml_dq($title);
  return <<~"END_STUB";
    ---
    title: $q_title
    lat: $lat
    lng: $lng
    ---

    TODO
    END_STUB
}

# Ask which key to file this place under. Returns the chosen key, or undef
# to skip. Enter accepts the default; "n" skips; anything else is taken as
# a replacement key. -- claude, 2026-07-03
sub ask_key ($default) {
  while (1) {
    print qq{  Add as "$default"?  [Enter = yes, n = skip, or type a different key]: };
    my $line = <STDIN>;
    return undef unless defined $line;

    $line =~ s/\A\s+|\s+\z//g;
    return $default            if $line eq '' || lc $line eq 'y' || lc $line eq 'yes';
    return undef               if lc $line eq 'n' || lc $line eq 'no';
    return $line               if $line =~ /\A[A-Za-z0-9_-]+\z/;

    say "  Please press Enter, type 'n', or type a key of letters, digits, - or _.";
  }
}

my @places = map { decode_utf8 $_ } @ARGV;

die "usage: $0 PLACE [PLACE ...]\n" unless @places;
die "no such directory: $LOCATIONS_DIR\n" unless -d $LOCATIONS_DIR;

my $added = 0;

for my $place (@places) {
  say "\n$place";

  my $hit = geocode($place);
  unless ($hit) {
    say "  no match; skipping.";
    next;
  }

  my $key = slugify($place);
  say "    title: $place";
  say "    lat:   $hit->{lat}";
  say "    lng:   $hit->{lon}";
  say "    found: $hit->{display_name}";

  my $chosen = ask_key($key);
  unless (defined $chosen) {
    say "  skipped.";
    next;
  }

  my $file = "$LOCATIONS_DIR/$chosen.md";
  if (-e $file) {
    say qq{  "$chosen" already exists; skipping.};
    next;
  }

  open my $fh, '>:encoding(UTF-8)', $file or die "can't write $file: $!\n";
  print $fh stub_for($place, $hit->{lat}, $hit->{lon});
  close $fh;

  $added++;
  say qq{  added "$chosen".};
}

say "\nDone. Added $added " . ($added == 1 ? 'location' : 'locations') . " to $LOCATIONS_DIR.";
